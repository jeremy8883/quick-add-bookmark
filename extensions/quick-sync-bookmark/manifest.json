{
  "manifest_version": 3,
  "name": "Quick Sync Bookmark",
  "version": "0.1.0",
  "description": "Sync bookmarks across browsers and devices using Dropbox. Three-way merge, append-only history, no accidental wipes.",
  "permissions": ["bookmarks", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/sync-bookmark-16.png",
      "32": "icons/sync-bookmark-32.png",
      "48": "icons/sync-bookmark-48.png",
      "128": "icons/sync-bookmark-128.png"
    },
    "default_title": "Sync Bookmarks"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Open sync status"
    }
  },
  "icons": {
    "16": "icons/sync-bookmark-16.png",
    "32": "icons/sync-bookmark-32.png",
    "48": "icons/sync-bookmark-48.png",
    "128": "icons/sync-bookmark-128.png"
  }
}
