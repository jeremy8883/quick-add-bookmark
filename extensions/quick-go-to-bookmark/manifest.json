{
  "manifest_version": 3,
  "name": "Quick Go To Bookmark",
  "version": "0.1.0",
  "description": "Quickly find and open bookmarks by typing — keyboard-first, ranked by recency and frequency.",
  "permissions": [
    "bookmarks",
    "storage",
    "favicon"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "go-to.html",
    "default_icon": {
      "16": "icons/bookmark-folder-16.png",
      "32": "icons/bookmark-folder-32.png",
      "48": "icons/bookmark-folder-48.png",
      "128": "icons/bookmark-folder-128.png"
    },
    "default_title": "Go to Bookmark"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+G",
        "mac": "Alt+Shift+G"
      },
      "description": "Find and open a bookmark"
    }
  },
  "icons": {
    "16": "icons/bookmark-folder-16.png",
    "32": "icons/bookmark-folder-32.png",
    "48": "icons/bookmark-folder-48.png",
    "128": "icons/bookmark-folder-128.png"
  }
}
