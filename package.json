{
  "name": "quick-add-bookmark",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension: add bookmarks with full folder tree selection.",
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "watch": "node watch.js",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeremy8883/quick-add-bookmark.git"
  },
  "bugs": {
    "url": "https://github.com/jeremy8883/quick-add-bookmark/issues"
  },
  "homepage": "https://github.com/jeremy8883/quick-add-bookmark#readme",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/chrome": "^0",
    "esbuild": "^0.25",
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.5"
  }
}
