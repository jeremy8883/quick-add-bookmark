{
  "name": "quick-add-bookmark",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension: add bookmarks with full folder tree selection.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "watch": "node scripts/watch.js",
    "lint": "eslint shared/ extensions/",
    "format": "prettier --write 'shared/**/*.ts' 'extensions/**/*.ts'",
    "format:check": "prettier --check 'shared/**/*.ts' 'extensions/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "cd dist/quick-add-bookmark && zip -r ../../quick-add-bookmark.zip . && cd ../..",
    "release": "npm run build && npm run package && gh release create v$(node -p \"require('./package.json').version\") quick-add-bookmark.zip --title \"v$(node -p \"require('./package.json').version\")\" --generate-notes",
    "version": "node scripts/version.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeremy8883/quick-add-bookmark.git"
  },
  "bugs": {
    "url": "https://github.com/jeremy8883/quick-add-bookmark/issues"
  },
  "homepage": "https://github.com/jeremy8883/quick-add-bookmark#readme",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/chrome": "^0",
    "esbuild": "^0.25",
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.5"
  }
}
