{
  "manifest_version": 3,
  "name": "Quick Add Bookmark",
  "version": "1.0.0",
  "description": "Add bookmarks with full folder tree selection — no simplified dialog.",
  "permissions": ["bookmarks", "activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/bookmark-16.png",
      "32": "icons/bookmark-32.png",
      "48": "icons/bookmark-48.png",
      "128": "icons/bookmark-128.png"
    },
    "default_title": "Add Bookmark"
  },
  "icons": {
    "16": "icons/bookmark-16.png",
    "32": "icons/bookmark-32.png",
    "48": "icons/bookmark-48.png",
    "128": "icons/bookmark-128.png"
  }
}
