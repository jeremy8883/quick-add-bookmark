{
  "manifest_version": 3,
  "name": "Quick Add Bookmark",
  "version": "1.0.0",
  "description": "Add bookmarks with full folder tree selection — no simplified dialog.",
  "permissions": ["bookmarks", "activeTab", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/bookmark-outline-16.png",
      "32": "icons/bookmark-outline-32.png",
      "48": "icons/bookmark-outline-48.png",
      "128": "icons/bookmark-outline-128.png"
    },
    "default_title": "Add Bookmark"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "Alt+Shift+D"
      },
      "description": "Add bookmark with folder selection"
    }
  },
  "icons": {
    "16": "icons/bookmark-16.png",
    "32": "icons/bookmark-32.png",
    "48": "icons/bookmark-48.png",
    "128": "icons/bookmark-128.png"
  }
}
